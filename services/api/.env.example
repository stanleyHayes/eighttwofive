# Required
MONGODB_URI=mongodb://localhost:27017

# Optional (defaults shown)
ENV=development
PORT=8080
MONGODB_DB=eightfivetwo
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Web app base URL — used to build sign-in links in emails
WEB_URL=http://localhost:5173

# Comma-separated emails that sign in with the admin role (merchant dashboard)
ADMIN_EMAILS=

# Resend — omit the key to disable email (sends are logged; waitlist still works,
# but customers can't get sign-in links). With a key, EMAIL_FROM MUST be an
# address on a domain you've VERIFIED in Resend. The default onboarding@resend.dev
# shared sender only delivers to your own Resend account email — every other
# customer is rejected (sign-in returns 500). Verify a domain, then set e.g.
# EMAIL_FROM=Eight Two Five <hello@eighttwofive.com>
RESEND_API_KEY=
EMAIL_FROM=Eight Two Five <onboarding@resend.dev>

# Cloudinary — omit to disable the upload-signing endpoint
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
