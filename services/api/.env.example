# Required
MONGODB_URI=mongodb://localhost:27017

# Optional (defaults shown)
ENV=development
PORT=8080
MONGODB_DB=eightfivetwo
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Web app base URL — used to build sign-in links in emails
WEB_URL=http://localhost:5173

# Comma-separated emails that sign in with the admin role (merchant dashboard)
ADMIN_EMAILS=

# Resend — omit to disable email (signups still work, sends are logged instead)
RESEND_API_KEY=
EMAIL_FROM=eightfivetwo <onboarding@resend.dev>

# Cloudinary — omit to disable the upload-signing endpoint
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
